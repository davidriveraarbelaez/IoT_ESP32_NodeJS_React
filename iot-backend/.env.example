# Puerto del servidor
PORT=3001

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/iot_db?retryWrites=true&w=majority

# JWT Secret (mínimo 32 caracteres, generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=secreto_jwt_aqui_minimo_32_caracteres

# API Key para dispositivos IoT (generar con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))")
API_KEY=api_key_secreta_aqui